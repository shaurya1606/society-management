# Required
DATABASE_URL=
AUTH_SECRET=generate-with-openssl-rand-base64-32

# App URL (emails + links) — set to your deployed URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — OAuth (redirect: {NEXT_PUBLIC_APP_URL}/api/auth/callback/{provider})
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Required on Vercel for OAuth callbacks
AUTH_TRUST_HOST=true

# Optional — transactional email (logs to console if unset)
RESEND_API_KEY=
ATOMQUEST_EMAIL_FROM=Society Maintenance Tracker <onboarding@resend.dev>

# Optional — enable email verification + 2FA flows (leave unset for hackathon demo)
# EMAIL_SERVICE=1
